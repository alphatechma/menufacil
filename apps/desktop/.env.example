# URL base da API (sem o sufixo /api — ele é adicionado automaticamente em src/config/env.ts).
# Em dev, a API NestJS roda na porta 3000.
VITE_API_URL=http://localhost:3000

# Opcional: URL do WebSocket. Se vazio, usa VITE_API_URL.
# VITE_WS_URL=http://localhost:3000

# Opcional: ambiente (dev | homol | prod). Se vazio, é inferido de import.meta.env.DEV.
# VITE_ENV=dev
