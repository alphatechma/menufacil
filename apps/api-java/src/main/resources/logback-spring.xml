<?xml version="1.0" encoding="UTF-8"?>
<!--
  Configuração de logs do MenuFácil API.

  Estratégia:
    - dev / default: texto colorido legível no terminal.
    - prod / hml:   JSON estruturado (Logstash encoder) pronto para
                    Loki / Elasticsearch / Datadog.
    - Sentry:       appender adicional sempre ativo; o controle por
                    nível mínimo vem das properties (sentry.logging.*).

  MDC propagado:
    - tenant_id, tenant_slug (TenantContext)
    - user_id, user_email    (SecurityContextHelper - opcional)
    - trace_id, span_id      (preenchidos pelo OpenTelemetry quando habilitado)
-->
<configuration>

    <!-- Defaults do Spring Boot (define CONSOLE_LOG_PATTERN, etc) -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ====================================================================
         APPENDER: console em texto (perfis dev / default)
         ==================================================================== -->
    <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %clr(%-5level) %clr([%X{tenant_slug:-}]){blue} %clr([trace=%X{trace_id:-}]){faint} %clr(%logger{36}){cyan} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ====================================================================
         APPENDER: console em JSON (perfis prod / hml)
         Compatível com Promtail/Loki, Filebeat/Elastic, Datadog, etc.
         ==================================================================== -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <timeZone>UTC</timeZone>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</pattern>
                </timestamp>
                <version/>
                <logLevel/>
                <threadName/>
                <loggerName>
                    <shortenedLoggerNameLength>40</shortenedLoggerNameLength>
                </loggerName>
                <message/>
                <stackTrace>
                    <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                        <maxDepthPerThrowable>30</maxDepthPerThrowable>
                        <maxLength>4096</maxLength>
                        <rootCauseFirst>true</rootCauseFirst>
                    </throwableConverter>
                </stackTrace>
                <mdc/>
                <pattern>
                    <pattern>
                        {
                          "service": "menufacil-api",
                          "env": "${SPRING_PROFILES_ACTIVE:-dev}"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>

    <!-- ====================================================================
         APPENDER: Sentry (logback bridge)
         Mapeia ERROR como eventos e INFO+ como breadcrumbs.
         Configurado em application.yml via sentry.logging.*
         ==================================================================== -->
    <appender name="SENTRY" class="io.sentry.logback.SentryAppender">
        <options>
            <!-- DSN/env vêm do application.yml + SentryAutoConfiguration -->
        </options>
    </appender>

    <!-- ====================================================================
         Roteamento por perfil
         ==================================================================== -->
    <springProfile name="prod,hml">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
            <appender-ref ref="SENTRY"/>
        </root>
    </springProfile>

    <springProfile name="!prod &amp; !hml">
        <root level="INFO">
            <appender-ref ref="CONSOLE_TEXT"/>
            <appender-ref ref="SENTRY"/>
        </root>
    </springProfile>

    <!-- Reduz ruído de libs barulhentas em qualquer ambiente -->
    <logger name="org.apache.kafka" level="WARN"/>
    <logger name="org.apache.http" level="WARN"/>
    <logger name="io.netty" level="WARN"/>
    <logger name="org.springframework.web.socket" level="INFO"/>
</configuration>
