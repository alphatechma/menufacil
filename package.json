{
  "name": "menufacil",
  "version": "0.0.1",
  "private": true,
  "description": "MenuFacil - Plataforma multi-tenant de delivery de comida",
  "scripts": {
    "dev": "pnpm run dev:api & pnpm run dev:web & pnpm run dev:super-admin",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:super-admin": "pnpm --filter super-admin dev",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:super-admin": "pnpm --filter super-admin build",
    "db:seed": "pnpm --filter api seed",
    "db:migration:generate": "pnpm --filter api migration:generate",
    "db:migration:run": "pnpm --filter api migration:run",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "bcrypt", "esbuild"]
  }
}
