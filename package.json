{
  "name": "menufacil",
  "version": "0.0.1",
  "private": true,
  "description": "MenuFácil - Plataforma multi-tenant de delivery de comida",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:customer": "pnpm --filter customer dev",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:admin": "pnpm --filter admin build",
    "build:customer": "pnpm --filter customer build",
    "dev:super-admin": "pnpm --filter super-admin dev",
    "build:super-admin": "pnpm --filter super-admin build",
    "db:seed": "pnpm --filter api seed",
    "db:migration:generate": "pnpm --filter api migration:generate",
    "db:migration:run": "pnpm --filter api migration:run",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "bcrypt", "esbuild"]
  }
}
