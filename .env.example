# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=menufacil
DB_PASSWORD=menufacil123
DB_DATABASE=menufacil

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (TROCAR EM PRODUCAO!)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# App
API_PORT=3000
API_PREFIX=api
NODE_ENV=development

# Upload / MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=menufacil
MINIO_SECRET_KEY=menufacil123
MINIO_BUCKET=menufacil
MINIO_USE_SSL=false
MAX_FILE_SIZE=5242880

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PIX (EFI/Gerencianet)
PIX_CLIENT_ID=xxx
PIX_CLIENT_SECRET=xxx
PIX_CERTIFICATE_PATH=./certs/pix.p12

